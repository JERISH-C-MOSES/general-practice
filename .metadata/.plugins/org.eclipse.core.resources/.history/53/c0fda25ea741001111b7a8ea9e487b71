public class ReadExcelData {
	
	public static String toReadData(int rowValue, int columValue)
	{
		String data="";
		try {
			File file = new File("C:\\Users\\hello\\Downloads\\simple_interest_test_data.xlsx");
			
			Workbook book = new XSSFWorkbook(file);
			
			Sheet sheet = book.getSheet("Sheet1");
			
			Row row = sheet.getRow(rowValue);
			
			Cell cell = row.getCell(columValue);
			
			//dataformatter it help to convert the data type
			DataFormatter dataformat = new DataFormatter();
			
			data = dataformat.formatCellValue(cell);

		} catch (Exception e) {
			e.printStackTrace();
		}	
	return data;
	}
	
